{
  "name": "byulmaru.co",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build && pnpm run verify:build",
    "preview": "pnpm run build && wrangler dev",
    "prepare": "react-router typegen",
    "check": "react-router typegen && tsc --noEmit && vitest run",
    "check:watch": "react-router typegen && tsc --noEmit --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write . && eslint --fix .",
    "deploy": "pnpm run build && wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:build": "node scripts/verify-build.mjs",
    "verify:browser": "node scripts/verification/react-browser.mjs"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.4",
    "@eslint/js": "^10.0.1",
    "@react-router/dev": "^8.2.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.4.0",
    "jsdom": "^29.1.1",
    "playwright-core": "1.61.1",
    "prettier": "^3.8.1",
    "prettier-plugin-brace-style": "^0.10.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.7",
    "vitest": "^4.1.10",
    "wrangler": "^4.81.0"
  },
  "dependencies": {
    "isbot": "^5.2.0",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.2.0"
  }
}
