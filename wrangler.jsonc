{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "byulmaru-co",
  "compatibility_date": "2026-04-17",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./build/client",
    "html_handling": "drop-trailing-slash",
  },
  "observability": {
    "enabled": true,
  },
  "preview_urls": false,
  "routes": [
    {
      "pattern": "byulmaru.co",
      "custom_domain": true,
    },
  ],
  "workers_dev": false,
}
