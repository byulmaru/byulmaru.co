{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "byulmaru-co",
  "compatibility_date": "2026-04-17",
  "compatibility_flags": ["nodejs_compat"],
  "main": ".svelte-kit/cloudflare/_worker.js",
  "assets": {
    "binding": "ASSETS",
    "directory": ".svelte-kit/cloudflare",
  },
  "observability": {
    "enabled": true,
  },
  "preview_urls": false,
  "routes": [
    {
      "pattern": "byulmaru.co",
      "custom_domain": true,
    },
  ],
  "workers_dev": false,
}
